<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>F1 Grand – Odtwarzacz</title>
  <style>
    body {
      margin: 0;
      height: 100vh;
      background: #0a0a0a;
      color: #eee;
      font-family: Arial, Helvetica, sans-serif;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 40px;
    }

    h1 {
      margin: 0;
      font-size: 3.2rem;
      letter-spacing: 2px;
      text-shadow: 0 0 15px #ff3366;
    }

    .container {
      position: relative;
      width: 90%;
      max-width: 960px;
      aspect-ratio: 16 / 9;
      background: #111;
      border: 2px solid #333;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 0 40px rgba(0,0,0,0.9);
    }

    video {
      width: 100%;
      height: 100%;
      object-fit: contain;
      display: none;          /* na początku ukryty */
    }

    .play-btn {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 120px;
      height: 120px;
      background: rgba(255, 50, 102, 0.9);
      color: white;
      font-size: 3.5rem;
      font-weight: bold;
      border: none;
      border-radius: 50%;
      cursor: pointer;
      transition: all 0.25s ease;
      box-shadow: 0 0 30px rgba(255, 50, 102, 0.6);
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .play-btn:hover {
      background: rgba(255, 50, 102, 1);
      transform: translate(-50%, -50%) scale(1.12);
      box-shadow: 0 0 60px rgba(255, 50, 102, 0.9);
    }

    .play-btn:active {
      transform: translate(-50%, -50%) scale(0.95);
    }
  </style>
</head>
<body>

  <h1>F1 Grand</h1>

  <div class="container">
    <video id="video" controls>
      <source src="f1grand.mp4" type="video/mp4">
      Twoja przeglądarka nie obsługuje odtwarzacza wideo.
    </video>

    <button class="play-btn" id="playButton">▶</button>
  </div>

  <script>
    const video = document.getElementById('video');
    const playButton = document.getElementById('playButton');

    playButton.addEventListener('click', () => {
      if (video.paused) {
        video.play();
        playButton.style.display = 'none';        // chowamy przycisk po starcie
        video.style.display = 'block';
      }
    });

    // ewentualnie – jeśli ktoś kliknie w sam film, też pauzuje/wznawia
    video.addEventListener('click', () => {
      if (video.paused) {
        video.play();
      } else {
        video.pause();
      }
    });
  </script>

</body>
</html>
